generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  STOCK
  CRYPTO
  COMMODITY
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  cashBalance  Float    @default(100.0)
  statusScore  Int      @default(0)
  inventory    Json     @default("{}") // ticker -> quantity
  trades       Trade[]
  positions    Position[]
  statusItems  UserStatusItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Asset {
  id           String    @id @default(uuid())
  ticker       String    @unique
  name         String
  type         AssetType
  currentPrice Float
  totalSupply  Float
  trades       Trade[]
  positions    Position[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum PositionSide {
  LONG
  SHORT
}

model Position {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  assetId          String
  asset            Asset        @relation(fields: [assetId], references: [id])
  side             PositionSide
  entryPrice       Float
  quantity         Float
  leverage         Int          @default(1)
  margin           Float
  liquidationPrice Float
  isActive         Boolean      @default(true)
  openedAt         DateTime     @default(now())
  closedAt         DateTime?
}

enum TradeType {
  BUY
  SELL
  BET
}

model Trade {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  assetId          String
  asset            Asset     @relation(fields: [assetId], references: [id])
  type             TradeType
  quantity         Float
  priceAtExecution Float
  timestamp        DateTime  @default(now())
}

model StatusItem {
  id          String   @id @default(uuid())
  name        String
  category    String   // Real Estate, Vehicles, Flex
  price       Float
  bonusScore  Int
  users       UserStatusItem[]
}

model UserStatusItem {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  statusItemId String
  statusItem   StatusItem @relation(fields: [statusItemId], references: [id])
  acquiredAt   DateTime   @default(now())
}

model MarketEvent {
  id          String   @id @default(uuid())
  type        String
  description String
  magnitude   Float
  duration    Int      // milliseconds
  assetTarget String?  // ticker or 'ALL'
  timestamp   DateTime @default(now())
}
